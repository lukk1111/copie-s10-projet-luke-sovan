    def action_guerir(self, dict_abilite: dict):
        """ Soigner une cible. Soi-même ou un autre héro. """

        cible_points_vie = self.cible.stats["point_vie"] # Points de vie de la cible
        cible_points_vie_max = self.cible.stats["points_vie_max"]

        dict_type_actions = self.raccourci_dict_abilite(dict_abilite)
        for types_actions, nom_actions in dict_type_actions.items():
            if types_actions == "ACTION_GUERIR":
                if self.nom_action in nom_actions: # si EAU_DIVINE est là
                    effet = nom_actions[self.nom_action] # effet = accéder à la valeur de EAU DIVINE, qui est : {"cible_possible": [0,1,2,3], "point_guerison": 3 }}

                    if "point_guerison" in effet:
                        soin = effet["point_guerion"]
                    else:
                        raise Exception("Aucun point de guérison.")

                    print(f"Points de vie de la cible avant soin ({cible_points_vie})")

                    if cible_points_vie_max > cible_points_vie:
                        cible_points_vie += soin
                    else:
                        print("Ne peut pas dépasser le points de vie max .")

                    return




